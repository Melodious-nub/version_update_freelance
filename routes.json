{
  "navigationFallback": {
    "rewrite": "/index.html",
    "exclude": [
      "/products/*",
      "/sitemap.xml",
      "/robots.txt",
      "/*.{js,css,png,jpg,jpeg,gif,svg,ico,woff,woff2,ttf,eot,json,pdf}"
    ]
  },
  "responseOverrides": {
    "404": {
      "rewrite": "/index.html",
      "statusCode": 200
    }
  }
}